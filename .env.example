# ---- API (apps/api) ----
# 서버 포트
PORT=4000

# JWT 서명 시크릿 (배포 시 반드시 강한 랜덤 값으로 교체)
JWT_SECRET=change-me-in-production
# 액세스 토큰 만료 (예: 7d, 1h)
JWT_EXPIRES_IN=7d

# PostgreSQL 접속 문자열 (M0-3에서 사용, pg 준비 후 채움)
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/latestock

# CORS 허용 오리진 (FE dev 서버)
CORS_ORIGIN=http://localhost:5173

# ---- Web (apps/web) ----
# FE에서 접근할 API 베이스 URL (Vite는 VITE_ 접두사만 노출)
VITE_API_BASE_URL=http://localhost:4000
