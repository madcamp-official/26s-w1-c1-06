# ---- API (apps/api) ----
# 서버 포트
PORT=4000

# JWT 서명 시크릿 (배포 시 반드시 강한 랜덤 값으로 교체)
JWT_SECRET=change-me-in-production
# 액세스 토큰 만료 (예: 7d, 1h)
JWT_EXPIRES_IN=7d

# PostgreSQL 접속 문자열
# 로컬: postgresql://user:pass@localhost:5432/latestock
# Neon: Dashboard → Connection string → "Pooled connection" 권장
#   예) postgresql://USER:PASSWORD@ep-xxxx.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
# 팀 공유 DB면 팀원 모두 동일한 URL을 각자 .env에 넣습니다 (커밋 금지).
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DATABASE?sslmode=require

# CORS 허용 오리진 (쉼표로 여러 포트 가능. dev는 localhost:* 자동 허용)
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# ---- Web (apps/web) ----
# ⚠️ 이 값들은 실제로는 이 파일이 아니라 apps/web/.env 에 넣어야 Vite가 읽습니다.
# (Vite 루트가 apps/web이라 루트 .env는 API만 읽음). 여기는 팀 공유용 템플릿입니다.

# dev: 비우면 Vite 프록시(/api → localhost:4000). 배포 시 API URL 설정
VITE_API_BASE_URL=

# 카카오맵 JavaScript 키 (Kakao Developers → 앱 설정 → 앱 키 → JavaScript 키)
# 로컬: apps/web/.env에 채우면 dev 서버가 바로 읽음.
# VM 배포: 마찬가지로 VM의 apps/web/.env에 채워야 함 — deploy/release.sh가 빌드 직전
# 이 값이 비어있으면 배포를 즉시 중단시킨다(카카오맵이 빈 화면으로 배포되는 걸 막기 위함).
# 카카오 디벨로퍼스 콘솔 "플랫폼 → Web"에 배포 도메인/IP도 별도로 등록해야 함(키 등록과 별개).
VITE_KAKAO_JS_KEY=
